{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "../generated/prisma/package.json", "outDir": "./dist/generated/prisma" },
      { "include": "../generated/prisma/internal/package.json", "outDir": "./dist/generated/prisma/internal" }
    ]
  }
}
