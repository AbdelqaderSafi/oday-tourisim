generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id         String  @id @default(uuid()) @db.VarChar(36)
  email      String  @unique @db.VarChar(255)
  password   String  @db.Text
  name       String  @db.VarChar(255)
  is_deleted Boolean @default(false)

  @@map("admins")
}

model Service {
  id          String         @id @default(uuid()) @db.VarChar(36)
  title       String          @db.Text
  type        ServiceTypeEnum
  description String?         @db.Text
  notes       String?         @db.Text
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  checkouts Checkout[]

  @@map("services")
}

model Checkout {
  id                String    @id @default(uuid()) @db.VarChar(36)
  hotel_id          String    @db.VarChar(36)
  trip_id           String?   @db.VarChar(36)
  service_id        String?   @db.VarChar(36)
  start_date        DateTime
  end_date          DateTime?
  individual_number Int
  total_price       Decimal   @db.Decimal(10, 2)

  hotel             hotels    @relation(fields: [hotel_id], references: [id])
  trip              trips?    @relation(fields: [trip_id], references: [id])
  service           Service?  @relation(fields: [service_id], references: [id])

  @@index([hotel_id], map: "checkout_hotel_id_fkey")
  @@index([service_id], map: "checkout_service_id_fkey")
  @@index([trip_id], map: "checkout_trip_id_fkey")
  @@map("checkout")
}

model comments {
  id          String         @id @default(uuid())
  client_name String         @db.VarChar(255)
  stars       comments_stars
  comment     String         @db.Text
  trip_name   String?        @db.VarChar(255)
  is_hidden   Boolean        @default(false)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  is_deleted  Boolean        @default(false)
}

model gallery {
  id          String       @id @default(uuid()) @db.VarChar(36)
  image       String       @db.Text
  image_title String       @db.Text
  description String?      @db.Text
  type        gallery_type
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  is_deleted  Boolean        @default(false)

  assets   Asset[]    @relation("GalleryAssets")
}

model hotels {
  id                  String            @id @default(uuid()) @db.VarChar(36)
  destination         DestinatiosnEnum
  initial_price       Decimal           @db.Decimal(10, 2)
  stars               hotels_stars
  rating              HotelFilterRating
  is_discounted       Boolean           @default(false)
  discount_percentage Decimal?          @db.Decimal(5, 2)
  original_price      Decimal?          @db.Decimal(10, 2)
  youtube_video_url   String?           @db.Text

  is_deleted          Boolean           @default(false)
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  rooms        Room[]
  addons       HotelAddon[]
  translations HotelTranslation[]
  checkouts    Checkout[]
  assets       Asset[]    @relation("HotelAssets")
}

model HotelTranslation {
  id          String       @id @default(uuid()) @db.VarChar(36)
  hotel_id    String       @db.VarChar(36)
  language    LanguageEnum

  name        String       @db.VarChar(255)
  slug        String       @db.VarChar(255) @unique
  description String       @db.Text
  Facilities  Json

  hotel       hotels       @relation(fields: [hotel_id], references: [id], onDelete: Cascade)

  @@unique([hotel_id, language])
  @@map("hotel_translations")
}

model HotelAddon {
  id          String   @id @default(uuid()) @db.VarChar(36)
  price       Decimal  @db.Decimal(10, 2)

  hotel_id    String   @db.VarChar(36)
  hotel       hotels   @relation(fields: [hotel_id], references: [id], onDelete: Cascade)

  translations HotelAddonTranslation[]

  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("hotel_addons")
}

model HotelAddonTranslation {
  id          String       @id @default(uuid()) @db.VarChar(36)
  addon_id    String       @db.VarChar(36)
  language    LanguageEnum

  name        String       @db.VarChar(255)
  description String       @db.Text

  addon       HotelAddon   @relation(fields: [addon_id], references: [id], onDelete: Cascade)

  @@unique([addon_id, language])
  @@map("hotel_addon_translations")
}

model TripAddon {
  id          String   @id @default(uuid()) @db.VarChar(36)
  price       Decimal  @db.Decimal(10, 2)

  trip_id     String   @db.VarChar(36)
  trip        trips    @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  translations TripAddonTranslation[]

  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("trip_addons")
}

model TripAddonTranslation {
  id          String       @id @default(uuid()) @db.VarChar(36)
  addon_id    String       @db.VarChar(36)
  language    LanguageEnum

  name        String       @db.VarChar(255)
  description String       @db.Text

  addon       TripAddon    @relation(fields: [addon_id], references: [id], onDelete: Cascade)

  @@unique([addon_id, language])
  @@map("trip_addon_translations")
}

model Room {
  id         String   @id @default(uuid()) @db.VarChar(36)
  capacity   String   @db.VarChar(50)
  price      Decimal  @db.Decimal(10, 2)

  hotel_id   String   @db.VarChar(36)
  hotel      hotels   @relation(fields: [hotel_id], references: [id], onDelete: Cascade)

  translations RoomTranslation[]

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("room")
}

model RoomTranslation {
  id        String       @id @default(uuid()) @db.VarChar(36)
  room_id   String       @db.VarChar(36)
  language  LanguageEnum

  name      String       @db.VarChar(255)

  room      Room         @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([room_id, language])
  @@map("room_translations")
}

model offers {
  id          String   @id @default(uuid()) @db.VarChar(36)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  assets   Asset[]    @relation("OfferAssets")
}

model PhotoGallery {
  id          String   @id @default(uuid()) @db.VarChar(36)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  assets   Asset[]    @relation("PhotoGalleryAssets")

  @@map("photo_gallery")
}

model settings {
  id              String  @id @default(uuid())
  company_name_ar String? @db.Text
  company_name_en String? @db.Text
  location        String? @db.Text
  whatsapp_number String? @db.VarChar(50)
  phone_number    String? @db.VarChar(50)
  email           String? @db.VarChar(255)
  facebook_link   String? @db.Text
  instagram_link  String? @db.Text
  tiktok_link     String? @db.Text
  hero_title      String? @db.Text
  hero_subtitle   String? @db.Text
  badge           String? @db.VarChar(255)
}

model trips {
  id          String         @id @default(uuid()) @db.VarChar(36)
  price       Decimal        @db.Decimal(10, 2)
  start_time  String         @db.VarChar(255)
  end_time    String         @db.VarChar(255)

  is_deleted  Boolean        @default(false)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  options      TripOption[]
  addons       TripAddon[]
  translations TripTranslation[]
  checkouts    Checkout[]
  assets       Asset[]            @relation("TripAssets")
}

model TripTranslation {
  id          String       @id @default(uuid()) @db.VarChar(36)
  trip_id     String       @db.VarChar(36)
  language    LanguageEnum

  title       String       @db.VarChar(255)
  subtitle    String       @db.VarChar(255)
  slug        String       @db.VarChar(255) @unique
  description String       @db.Text
  duration    String       @db.VarChar(255)
  facilities  Json

  trip        trips        @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@unique([trip_id, language])
  @@map("trip_translations")
}

model TripOption {
  id         String   @id @default(uuid()) @db.VarChar(36)
  price      Decimal  @db.Decimal(10, 2)

  trip_id   String   @db.VarChar(36)
  trip      trips   @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  translations OptionTranslation[]

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("trip_options")
}
model OptionTranslation {
  id        String       @id @default(uuid()) @db.VarChar(36)
  option_id   String       @db.VarChar(36)
  language  LanguageEnum

  name      String       @db.VarChar(255)

  option      TripOption         @relation(fields: [option_id], references: [id], onDelete: Cascade)

  @@unique([option_id, language])
  @@map("trip_option_translations")
}

model SecurityServiceType {
  id           String   @id @default(uuid()) @db.VarChar(36)
  price        Decimal  @db.Decimal(10, 2)

  translations SecurityServiceTypeTranslation[]

  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("security_service_types")
}

model SecurityServiceTypeTranslation {
  id              String              @id @default(uuid()) @db.VarChar(36)
  service_type_id String              @db.VarChar(36)
  language        LanguageEnum

  name            String              @db.VarChar(255)
  description     String              @db.Text

  service_type    SecurityServiceType @relation(fields: [service_type_id], references: [id], onDelete: Cascade)

  @@unique([service_type_id, language])
  @@map("security_service_type_translations")
}

model NationalityPricing {
  id          String      @id @default(uuid()) @db.VarChar(36)
  nationality Nationality @unique
  price_24h   Decimal     @db.Decimal(10, 2)
  price_72h   Decimal     @db.Decimal(10, 2)

  is_deleted  Boolean     @default(false)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  @@map("nationality_pricing")
}

model AirlinePricing {
  id         String  @id @default(uuid()) @db.VarChar(36)
  airline    Airline @unique
  price      Decimal @db.Decimal(10, 2)

  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("airline_pricing")
}

model Asset {
  id                  String              @id @default(uuid()) @db.VarChar(36)
  storageProviderName StorageProviderName @default(IMAGE_KIT) @map("storage_provider_name")
  fileId              String              @unique @map("file_id")
  url                 String              @db.Text
  fileType            String              @map("file_type") @db.Text
  fileSizeInKB        Int                 @map("file_size_in_kb") @db.UnsignedInt
  kind                AssetKind

  hotelId             String?             @map("hotel_id") @db.VarChar(36)
  hotel               hotels?             @relation("HotelAssets", fields: [hotelId], references: [id])

  tripId              String?             @map("trip_id") @db.VarChar(36)
  trip                trips?              @relation("TripAssets", fields: [tripId], references: [id])

  offerId             String?             @map("offer_id") @db.VarChar(36)
  offer               offers?             @relation("OfferAssets", fields: [offerId], references: [id])

  galleryId           String?             @map("gallery_id") @db.VarChar(36)
  gallery             gallery?            @relation("GalleryAssets", fields: [galleryId], references: [id])

  photoGalleryId      String?             @map("photo_gallery_id") @db.VarChar(36)
  photoGallery        PhotoGallery?       @relation("PhotoGalleryAssets", fields: [photoGalleryId], references: [id])

  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  
  @@index([tripId])
  @@index([hotelId])
  @@index([galleryId])
  @@index([offerId])
  @@index([photoGalleryId])

  @@map("assets")
}
enum LanguageEnum {
  ar
  en
}

enum HotelFilterRating {
  UNRATED 
  MOST_BOOKED
  TOP_RATED 
  LOWEST_PRICE 
}
enum DestinatiosnEnum {
  SHARM_EL_SHEIKH
  EL_GHARDQA
  EL_AIN_SOKHNA
  DAHAB
}
enum ServiceTypeEnum {
  FLYING
  TRANSPORTATION
  INSURANCE
  OTHER
}

enum comments_stars {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum hotels_stars {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}


enum gallery_type {
  COMPANY
  CLIENT
}


enum StorageProviderName {
  IMAGE_KIT
}
enum AssetKind {
  HOTEL_MAIN_IMAGE
  HOTEL_GALLERY_IMAGE
  TRIP_MAIN_IMAGE
  TRIP_GALLERY_IMAGE
  OFFER_IMAGE
  GALLERY_IMAGE
  PHOTO_GALLERY_IMAGE
}

enum Nationality {
  PALESTINIAN
  PALESTINIAN_SHARM_ONLY
  PALESTINIAN_SYRIAN
  SYRIAN
  LEBANESE
  IRAQI
  IRAQ_DOCUMENT
  LIBYAN
  YEMENI
  AFRICAN
  ASIAN
  KAZAKHSTAN
  UZBEKISTAN
  TURKMENISTAN
  KYRGYZSTAN
  TAJIKISTAN
  SUDANESE
  SAINT_KITTS_AND_NEVIS
  DOMINICA
}

enum Airline {
  QATAR_AIRWAYS
  EMIRATES
  AEGEAN
  TURKISH_AIRLINES
  OMAN_AIR
  OTHER
}