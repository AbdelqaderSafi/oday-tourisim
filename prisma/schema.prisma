enum ServiceTypeEnum {
  FLYING
  TRANSPORTATION
  INSURANCE
  OTHER
}

enum comments_stars {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum hotels_stars {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum offers_currency {
  USD
  EUR
  EGP
  ILS
}

enum gallery_type {
  COMPANY
  CLIENT
}

enum trips_currency {
  USD
  EUR
  EGP
  ILS
}
enum StorageProviderName {
  IMAGE_KIT
}
enum AssetKind {
  HOTEL_IMAGE
  TRIP_IMAGE
  OFFER_IMAGE
  GALLERY_IMAGE

}