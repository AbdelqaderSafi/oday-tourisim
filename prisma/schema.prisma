generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id         String  @id @default(uuid()) @db.VarChar(36)
  email      String  @unique @db.VarChar(255)
  password   String  @db.Text
  name       String  @db.VarChar(255)
  is_deleted Boolean @default(false)

  @@map("admins")
}

model Service {
  id          BigInt          @id @default(autoincrement())
  title       String          @db.Text
  type        ServiceTypeEnum
  description String?         @db.Text
  notes       String?         @db.Text
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  checkouts Checkout[]

  @@map("services")
}

model Checkout {
  id                BigInt    @id @default(autoincrement())
  hotel_id          String    @db.VarChar(36)
  trip_id           String?   @db.VarChar(36)
  service_id        BigInt?
  start_date        DateTime
  end_date          DateTime?
  individual_number Int
  total_price       Decimal   @db.Decimal(10, 2)

  hotel             hotels    @relation(fields: [hotel_id], references: [id])
  trip              trips?    @relation(fields: [trip_id], references: [id])
  service           Service?  @relation(fields: [service_id], references: [id])

  @@index([hotel_id], map: "checkout_hotel_id_fkey")
  @@index([service_id], map: "checkout_service_id_fkey")
  @@index([trip_id], map: "checkout_trip_id_fkey")
  @@map("checkout")
}

model comments {
  id          BigInt         @id @default(autoincrement())
  client_name String         @db.VarChar(255)
  stars       comments_stars
  comment     String         @db.Text
  trip_name   String?        @db.VarChar(255)
  is_hidden   Boolean        @default(false)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  is_deleted  Boolean        @default(false)
}

model gallery {
  id          BigInt       @id @default(autoincrement())
  image       String       @db.Text
  image_title String       @db.Text
  description String?      @db.Text
  type        gallery_type
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  is_deleted  Boolean        @default(false)
}

model hotels {
  id           String       @id @db.VarChar(36)
  name         String       @db.VarChar(255)
  description  String?      @db.Text
  stars        hotels_stars
  hotel_images String?      @db.Text
  features     Json
  is_deleted   Boolean      @default(false)
  city         String       @db.VarChar(255)
  price_per_night Decimal      @db.Decimal(10, 2)
  duration     String       @db.VarChar(255)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  checkouts Checkout[]
}

model offers {
  id          String          @id @db.VarChar(36)
  destination String          @db.Text
  price       Decimal         @db.Decimal(10, 2)
  currency    offers_currency
  duration    String          @db.VarChar(255)
  offer_image String          @db.Text
  services    Json
  is_featured Boolean         @default(false)
  is_deleted  Boolean         @default(false)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  
}

model settings {
  id              BigInt  @id @default(autoincrement())
  company_name_ar String? @db.Text
  company_name_en String? @db.Text
  location        String? @db.Text
  whatsapp_number String? @db.VarChar(50)
  phone_number    String? @db.VarChar(50)
  email           String? @db.VarChar(255)
  new_column      BigInt?
  facebook_link   String? @db.Text
  instagram_link  String? @db.Text
  tiktok_link     String? @db.Text
  hero_title      String? @db.Text
  hero_subtitle   String? @db.Text
  badge           String? @db.VarChar(255)
}

model trips {
  id          String         @id @db.VarChar(36)
  title       String         @db.VarChar(255)
  description String?        @db.Text
  duration    String         @db.VarChar(255)
  price       Decimal        @db.Decimal(10, 2)
  currency    trips_currency
  country     String         @db.VarChar(255)
  trip_images String         @db.Text
  notes       String?        @db.Text
  is_deleted  Boolean        @default(false)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  checkouts Checkout[]
}

enum ServiceTypeEnum {
  FLYING
  TRANSPORTATION
  INSURANCE
  OTHER
}

enum comments_stars {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum hotels_stars {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum offers_currency {
  USD
  EUR
  EGP
  ILS
}

enum gallery_type {
  COMPANY
  CLIENT
}

enum trips_currency {
  USD
  EUR
  EGP
  ILS
}
